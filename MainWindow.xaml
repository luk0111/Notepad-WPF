<Window x:Class="Notepad__WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Notepad__WPF"
        Title="Notepad++ WPF - Rusu Luca-Andrei" Height="700" Width="1000"
        Background="#F5F8FC">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- tema -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
        <SolidColorBrush x:Key="PrimaryBlueDark" Color="#1976D2"/>
        <SolidColorBrush x:Key="PrimaryBlueLight" Color="#BBDEFB"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#03A9F4"/>
        <SolidColorBrush x:Key="BackgroundWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BackgroundLight" Color="#F5F8FC"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E0E6ED"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="ToolbarGradientStart" Color="#2196F3"/>
        <SolidColorBrush x:Key="ToolbarGradientEnd" Color="#1976D2"/>
        
        <!-- meniu -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        
        <!-- meniu dropdown -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="Role" Value="SubmenuItem">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Toolbar button style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- add tab -->
        <Style x:Key="AddTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryBlueDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Close tab button -->
        <Style x:Key="CloseTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <TextBlock Text="×" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,-2,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- tema tab -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderLight}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0"
                                Margin="2,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BackgroundWhite}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,2,1,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PrimaryBlueLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- statusbar -->
        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- textbox -->
        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundWhite}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource PrimaryBlueLight}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBlue}"/>
        </Style>
        
        <!-- Search panel button -->
        <Style x:Key="SearchPanelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBlueDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New" Executed="New_Executed"/>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Executed"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Executed"/>
        <CommandBinding Command="local:CustomCommands.Search" Executed="Search_Executed"/>
        <CommandBinding Command="local:CustomCommands.Replace" Executed="Replace_Executed"/>
        <CommandBinding Command="local:CustomCommands.GoToLine" Executed="GoToLine_Executed"/>
        <CommandBinding Command="local:CustomCommands.ZoomIn" Executed="ZoomIn_Executed"/>
        <CommandBinding Command="local:CustomCommands.ZoomOut" Executed="ZoomOut_Executed"/>
        <CommandBinding Command="local:CustomCommands.WordWrap" Executed="WordWrap_Executed"/>
    </Window.CommandBindings>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="ApplicationCommands.New"/>
        <KeyBinding Gesture="Ctrl+O" Command="ApplicationCommands.Open"/>
        <KeyBinding Gesture="Ctrl+S" Command="ApplicationCommands.Save"/>
        <KeyBinding Gesture="Ctrl+F" Command="local:CustomCommands.Search"/>
        <KeyBinding Gesture="Ctrl+H" Command="local:CustomCommands.Replace"/>
        <KeyBinding Gesture="Ctrl+G" Command="local:CustomCommands.GoToLine"/>
    </Window.InputBindings>
    
    <DockPanel>
        <!-- meniu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="New_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open" Click="Open_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save" Click="Save_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As" Click="SaveAs_Click"/>
                <Separator/>
                <MenuItem Header="Close _All Tabs" Click="CloseAllTabs_Click"/>
                <Separator/>
                <MenuItem Header="_Recent Files" x:Name="RecentFilesMenu"/>
                <Separator/>
                <MenuItem Header="_Close Tab" Click="CloseTab_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="ApplicationCommands.Undo" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" Command="ApplicationCommands.Redo" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Cut" Command="ApplicationCommands.Cut" InputGestureText="Ctrl+X"/>
                <MenuItem Header="_Copy" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"/>
                <MenuItem Header="_Paste" Command="ApplicationCommands.Paste" InputGestureText="Ctrl+V"/>
                <MenuItem Header="Select _All" Command="ApplicationCommands.SelectAll" InputGestureText="Ctrl+A"/>
                <Separator/>
                <MenuItem Header="_Delete Line" Click="DeleteLine_Click"/>
                <MenuItem Header="Duplicate _Line" Click="DuplicateLine_Click"/>
            </MenuItem>
            <MenuItem Header="_Search">
                <MenuItem Header="_Find..." Command="local:CustomCommands.Search" InputGestureText="Ctrl+F"/>
                <MenuItem Header="_Replace..." Command="local:CustomCommands.Replace" InputGestureText="Ctrl+H"/>
                <Separator/>
                <MenuItem Header="_Go To Line..." Command="local:CustomCommands.GoToLine" InputGestureText="Ctrl+G"/>
                <Separator/>
                <MenuItem Header="Scope">
                    <MenuItem x:Name="SelectedTabScopeMenuItem" Header="Selected tab" IsCheckable="True" IsChecked="True" Click="ScopeMenu_Click"/>
                    <MenuItem x:Name="AllTabsScopeMenuItem" Header="All tabs" IsCheckable="True" Click="ScopeMenu_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Word Wrap" x:Name="WordWrapMenuItem" IsCheckable="True" Click="WordWrap_Click"/>
                <Separator/>
                <MenuItem Header="Zoom _In" Command="local:CustomCommands.ZoomIn" InputGestureText="Ctrl++"/>
                <MenuItem Header="Zoom _Out" Command="local:CustomCommands.ZoomOut" InputGestureText="Ctrl+-"/>
                <MenuItem Header="_Reset Zoom" Click="ResetZoom_Click"/>
                <Separator/>
                <MenuItem Header="Show _Line Numbers" x:Name="LineNumbersMenuItem" IsCheckable="True" IsChecked="True"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>
        
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="4">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1E88E5" Offset="0"/>
                    <GradientStop Color="#1565C0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ToolbarButtonStyle}" Click="New_Click" ToolTip="New (Ctrl+N)">
                    <TextBlock Text="📄" FontSize="16"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Click="Open_Click" ToolTip="Open (Ctrl+O)">
                    <TextBlock Text="📂" FontSize="16"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Click="Save_Click" ToolTip="Save (Ctrl+S)">
                    <TextBlock Text="💾" FontSize="16"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Click="SaveAll_Click" ToolTip="Save All">
                    <TextBlock Text="📑" FontSize="16"/>
                </Button>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Background="#64B5F6" Margin="6,4"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Click="Undo_Click" ToolTip="Undo (Ctrl+Z)">
                    <TextBlock Text="↩" FontSize="16"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Click="Redo_Click" ToolTip="Redo (Ctrl+Y)">
                    <TextBlock Text="↪" FontSize="16"/>
                </Button>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Background="#64B5F6" Margin="6,4"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="local:CustomCommands.Search" ToolTip="Find (Ctrl+F)">
                    <TextBlock Text="🔍" FontSize="16"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="local:CustomCommands.Replace" ToolTip="Replace (Ctrl+H)">
                    <TextBlock Text="🔄" FontSize="16"/>
                </Button>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Background="#64B5F6" Margin="6,4"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="local:CustomCommands.ZoomIn" ToolTip="Zoom In (Ctrl++)">
                    <TextBlock Text="🔎+" FontSize="14"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="local:CustomCommands.ZoomOut" ToolTip="Zoom Out (Ctrl+-)">
                    <TextBlock Text="🔎-" FontSize="14"/>
                </Button>
                <TextBlock x:Name="ZoomLevelText" Text="100%" Foreground="White" 
                           VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
            <Separator Background="#64B5F6"/>
            <StatusBarItem>
                <TextBlock x:Name="LineColText" Text="Ln 1, Col 1"/>
            </StatusBarItem>
            <Separator Background="#64B5F6"/>
            <StatusBarItem>
                <TextBlock x:Name="CharCountText" Text="0 characters"/>
            </StatusBarItem>
            <Separator Background="#64B5F6"/>
            <StatusBarItem>
                <TextBlock x:Name="FileTypeText" Text="Plain Text"/>
            </StatusBarItem>
            <Separator Background="#64B5F6"/>
            <StatusBarItem>
                <TextBlock x:Name="EncodingText" Text="UTF-8"/>
            </StatusBarItem>
            <Separator Background="#64B5F6"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="ZoomStatusText" Text="100%"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Search/Replace Panel -->
        <Border x:Name="SearchPanel" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="{StaticResource BackgroundLight}" 
                BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Find:" VerticalAlignment="Center" Margin="0,0,8,0" 
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" Margin="0,0,8,0" Padding="8,6"
                         BorderBrush="{StaticResource BorderLight}" BorderThickness="1"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Find Next" Click="FindNext_Click" 
                            Style="{StaticResource SearchPanelButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="Find Previous" Click="FindPrevious_Click" 
                            Style="{StaticResource SearchPanelButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="Count" Click="CountMatches_Click" 
                            Style="{StaticResource SearchPanelButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="✕" Click="CloseSearch_Click" 
                            Style="{StaticResource SearchPanelButtonStyle}" FontWeight="Bold"/>
                </StackPanel>
                
                <TextBlock x:Name="ReplaceLabel" Grid.Row="1" Text="Replace:" VerticalAlignment="Center" 
                           Margin="0,8,8,0" Foreground="{StaticResource TextPrimary}" Visibility="Collapsed"/>
                <TextBox x:Name="ReplaceTextBox" Grid.Row="1" Grid.Column="1" Margin="0,8,8,0" Padding="8,6"
                         BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Visibility="Collapsed"/>
                <StackPanel x:Name="ReplaceButtons" Grid.Row="1" Grid.Column="2" Orientation="Horizontal" 
                            Margin="0,8,0,0" Visibility="Collapsed">
                    <Button Content="Replace" Click="Replace_Click" 
                            Style="{StaticResource SearchPanelButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="Replace All" Click="ReplaceAll_Click" 
                            Style="{StaticResource SearchPanelButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Go To Line Dialog (shown inline) -->
        <Border x:Name="GoToLinePanel" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="{StaticResource BackgroundLight}" 
                BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1"
                Padding="12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Go to line:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBox x:Name="GoToLineTextBox" Width="100" Padding="8,6" Margin="0,0,8,0"
                         BorderBrush="{StaticResource BorderLight}" BorderThickness="1"
                         KeyDown="GoToLineTextBox_KeyDown"/>
                <Button Content="Go" Click="GoToLine_Click" 
                        Style="{StaticResource SearchPanelButtonStyle}" Margin="0,0,4,0"/>
                <Button Content="✕" Click="CloseGoToLine_Click" 
                        Style="{StaticResource SearchPanelButtonStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- file explorer -->
        <Border DockPanel.Dock="Left" Width="300" Padding="8" Background="{StaticResource BackgroundLight}" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock Text="File Explorer" FontWeight="SemiBold" Margin="2,0,0,8" Foreground="{StaticResource TextPrimary}" DockPanel.Dock="Top"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TreeView x:Name="FileTreeView" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- containere tab -->
        <TabControl x:Name="TabContainer" SelectionChanged="TabContainer_SelectionChanged"
                    Background="{StaticResource BackgroundLight}"
                    BorderBrush="{StaticResource BorderLight}">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- buttonul de adaugare tab -->
                        <Border Grid.Row="0" Background="{StaticResource BackgroundLight}" Padding="4,4,4,0">
                            <StackPanel Orientation="Horizontal">
                                <TabPanel IsItemsHost="True"/>
                                <Button Content="+" 
                                        Width="28" Height="28"
                                        Margin="6,0,0,0"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        VerticalAlignment="Center"
                                        Click="AddTab_Click"
                                        ToolTip="Add new tab"
                                        Style="{StaticResource AddTabButtonStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- content tab -->
                        <Border Grid.Row="1" 
                                BorderBrush="{StaticResource BorderLight}" 
                                BorderThickness="1"
                                Background="{StaticResource BackgroundWhite}"
                                CornerRadius="0,0,4,4">
                            <ContentPresenter ContentSource="SelectedContent" Margin="2"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ModifiedIndicator" 
                                 Width="8" Height="8" 
                                 Fill="#EF4444" 
                                 Margin="0,0,5,0"
                                 Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding Title}" Foreground="#1E293B" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource CloseTabButtonStyle}" 
                                Click="CloseTabButton_Click" Tag="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Line numbers -->
                        <Border x:Name="LineNumberBorder" Background="#F8FAFC" 
                                BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,1,0"
                                Padding="8,0">
                            <TextBlock x:Name="LineNumbers" 
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="Consolas" FontSize="{Binding DataContext.EditorFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       TextAlignment="Right" Padding="0,1,0,0"/>
                        </Border>
                        
                        <!-- Editor -->
                        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto" x:Name="EditorScrollViewer">
                            <TextBox x:Name="Editor" 
                                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="{Binding DataContext.WordWrapMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                     FontFamily="Consolas"
                                     FontSize="{Binding DataContext.EditorFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                     TextChanged="Editor_TextChanged"
                                     SelectionChanged="Editor_SelectionChanged"
                                     Style="{StaticResource EditorTextBoxStyle}"
                                     BorderThickness="0"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"/>
                        </ScrollViewer>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>
